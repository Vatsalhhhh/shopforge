# ================================================================
# ECOMMERCE PLATFORM — ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ================================================================

# ── Application ─────────────────────────────────────────────────
APP_ENV=development                        # development | test | production
DEBUG=true                                 # false in production
APP_NAME="ShopForge"
APP_VERSION="1.0.0"
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ── Security ────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database (PostgreSQL) ────────────────────────────────────────
POSTGRES_HOST=localhost                    # "postgres" inside Docker
POSTGRES_PORT=5432
POSTGRES_DB=shopforge
POSTGRES_USER=shopforge_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
# Full URL (auto-built by config.py, can also set directly):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/db

# ── Redis ───────────────────────────────────────────────────────
REDIS_HOST=localhost                       # "redis" inside Docker
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_DB=0
# Full URL (auto-built by config.py):
# REDIS_URL=redis://:password@host:6379/0

# ── Stripe ──────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_CHANGE_ME
# Get from: https://dashboard.stripe.com/test/webhooks
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ── Email (SMTP) ─────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=CHANGE_ME_app_password
EMAIL_FROM_NAME="ShopForge"
EMAIL_FROM_ADDRESS=noreply@shopforge.com

# ── AWS / S3-Compatible Storage (optional) ──────────────────────
# Leave blank to use local filesystem storage in development
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=
S3_ENDPOINT_URL=                           # Set for MinIO/R2/DigitalOcean Spaces

# ── Frontend (Next.js public vars — prefix NEXT_PUBLIC_) ────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_CHANGE_ME
NEXT_PUBLIC_APP_NAME="ShopForge"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Rate Limiting ────────────────────────────────────────────────
RATE_LIMIT_AUTH_PER_MINUTE=5
RATE_LIMIT_API_PER_MINUTE=100

# ── CORS ────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Logging ─────────────────────────────────────────────────────
LOG_LEVEL=INFO                             # DEBUG | INFO | WARNING | ERROR
